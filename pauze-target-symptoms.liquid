{% comment %}
  PAUZE TARGET SYMPTOMS — Réplica del bloque "Target Symptoms at the Source" de O Positiv home
  Foto lifestyle a la izquierda + texto con 3 stats grandes a la derecha
{% endcomment %}

<section class="pauze-section pauze-section--cacao pauze-target" data-section-id="{{ section.id }}">
  <div class="pauze-container">
    <div class="pauze-target__layout">

      <div class="pauze-target__media pauze-reveal">
        {% if section.settings.image != blank %}
          <img src="{{ section.settings.image | image_url: width: 1200 }}" alt="{{ section.settings.alt | default: 'Pauze ritual nocturno' }}" loading="lazy">
        {% else %}
          <div class="pauze-target__placeholder">
            <div class="pauze-target__placeholder-inner">
              <span class="pauze-target__placeholder-emoji">🌙</span>
              <p>[FOTO LIFESTYLE NOCTURNA]<br><small>Mano sosteniendo taza humeante en mesita de noche, luz cálida</small></p>
            </div>
          </div>
        {% endif %}
      </div>

      <div class="pauze-target__content pauze-reveal">
        <span class="pauze-eyebrow pauze-eyebrow--gold">{{ section.settings.eyebrow | default: 'NUESTRO MÉTODO' }}</span>
        <h2 class="pauze-h2">{{ section.settings.heading | default: 'Activos con evidencia real,' }}<br><em>{{ section.settings.heading_italic | default: 'no marketing' }}</em>.</h2>
        <p class="pauze-target__sub">{{ section.settings.sub | default: 'Una formulación honesta con dosis clínicas declaradas en el frente del pack. Sin proprietary blend, sin números mágicos.' }}</p>

        <div class="pauze-target__stats">
          {% for block in section.blocks %}
            <div class="pauze-target__stat">
              <div class="pauze-target__stat-num">{{ block.settings.num }}</div>
              <div class="pauze-target__stat-label">{{ block.settings.label }}</div>
            </div>
          {% endfor %}
        </div>

        {% if section.settings.cta_text != blank %}
          <a href="{{ section.settings.cta_url | default: '/products/pauze-cocoa' }}" class="pauze-btn pauze-btn--crema pauze-mt-3">
            {{ section.settings.cta_text }}
          </a>
        {% endif %}
      </div>

    </div>
  </div>
</section>

<style>
.pauze-target__layout {
  display: grid;
  grid-template-columns: 1fr;
  gap: 2.5rem;
  align-items: center;
}
@media (min-width: 900px) {
  .pauze-target__layout { grid-template-columns: 1fr 1fr; gap: 4rem; }
}

.pauze-target__media {
  aspect-ratio: 4 / 5;
  border-radius: 20px;
  overflow: hidden;
  background: var(--pauze-cacao-dark);
}
@media (min-width: 900px) {
  .pauze-target__media { aspect-ratio: 4 / 5; }
}
.pauze-target__media img { width: 100%; height: 100%; object-fit: cover; }
.pauze-target__placeholder {
  width: 100%; height: 100%;
  display: flex; align-items: center; justify-content: center;
  padding: 2rem;
  background: linear-gradient(135deg, var(--pauze-cacao) 0%, var(--pauze-cacao-dark) 100%);
}
.pauze-target__placeholder-inner {
  text-align: center;
  color: var(--pauze-beige);
}
.pauze-target__placeholder-emoji {
  font-size: 5rem;
  display: block;
  margin-bottom: 1rem;
}
.pauze-target__placeholder p {
  font-style: italic;
  opacity: 0.7;
  font-size: 0.9rem;
}
.pauze-target__placeholder small { display: block; opacity: 0.5; margin-top: 0.5rem; }

.pauze-target__content .pauze-h2 em { font-style: italic; color: var(--pauze-dorado); }
.pauze-target__sub {
  font-size: 1.05rem;
  line-height: 1.6;
  color: var(--pauze-beige);
  margin: 1rem 0 2rem;
}

.pauze-target__stats {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1rem;
  padding: 1.5rem 0;
  border-top: 1px solid rgba(246, 241, 233, 0.15);
  border-bottom: 1px solid rgba(246, 241, 233, 0.15);
}
@media (max-width: 480px) {
  .pauze-target__stats { grid-template-columns: 1fr; gap: 1.25rem; }
}
.pauze-target__stat { text-align: center; }
.pauze-target__stat-num {
  font-family: var(--pauze-font-display);
  font-style: italic;
  font-weight: 700;
  font-size: clamp(2.5rem, 5vw, 3.5rem);
  color: var(--pauze-verde-bright);
  line-height: 1;
  margin-bottom: 0.35rem;
}
.pauze-target__stat-label {
  font-size: 0.78rem;
  font-weight: 600;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: var(--pauze-crema);
  opacity: 0.85;
  line-height: 1.3;
}
</style>

{% schema %}
{
  "name": "Pauze: Target Symptoms",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "NUESTRO MÉTODO" },
    { "type": "text", "id": "heading", "label": "Título línea 1", "default": "Activos con evidencia real," },
    { "type": "text", "id": "heading_italic", "label": "Título italic", "default": "no marketing" },
    { "type": "textarea", "id": "sub", "label": "Subtítulo" },
    { "type": "image_picker", "id": "image", "label": "Imagen lifestyle" },
    { "type": "text", "id": "alt", "label": "Alt text" },
    { "type": "text", "id": "cta_text", "label": "CTA" },
    { "type": "url", "id": "cta_url", "label": "URL CTA" }
  ],
  "blocks": [
    {
      "type": "stat",
      "name": "Stat",
      "settings": [
        { "type": "text", "id": "num", "label": "Número", "default": "3" },
        { "type": "text", "id": "label", "label": "Label", "default": "Activos clínicos" }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
    {
      "name": "Pauze: Target Symptoms",
      "blocks": [
        { "type": "stat", "settings": { "num": "3", "label": "Activos clínicos declarados" } },
        { "type": "stat", "settings": { "num": "+340", "label": "Personas tomando Pauze" } },
        { "type": "stat", "settings": { "num": "100%", "label": "Hecho en Argentina" } }
      ]
    }
  ]
}
{% endschema %}
