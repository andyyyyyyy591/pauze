{% comment %}
  ============================================
  PAUZE BRAND STYLES — Sistema de diseño global
  ============================================
  Incluir en theme.liquid después de pauze-fonts:
  {% raw %}{% render 'pauze-brand-styles' %}{% endraw %}
  
  Paleta NO PASTEL — vibrante manteniendo cacao+crema como ADN
{% endcomment %}

<style>
:root {
  /* === BRAND BASE === */
  --pauze-cacao: #5A3E2B;
  --pauze-cacao-dark: #3D2C1F;
  --pauze-cacao-deep: #2E1F14;
  --pauze-cacao-light: #8B6A52;
  --pauze-crema: #F6F1E9;
  --pauze-crema-warm: #FAF4EC;
  --pauze-arena: #E6D8C8;
  --pauze-beige: #D4C1AE;
  --pauze-off-white: #FAFAF8;
  --pauze-off-black: #1A1612;
  --pauze-gris: #8A837C;
  --pauze-gris-dark: #5C5650;

  /* === VERDES SATURADOS (NO PASTEL) === */
  --pauze-verde: #3B7A2C;          /* CTAs principales - verde bosque */
  --pauze-verde-dark: #2A5C20;     /* Hover */
  --pauze-verde-bright: #5DAA3F;   /* Énfasis, ratings extras */
  --pauze-verde-deep: #1F4318;     /* Texto sobre verde claro */
  --pauze-verde-pale: #DBE8CC;     /* Solo chips sutiles, NO fondos grandes */

  /* === ACENTOS VIBRANTES === */
  --pauze-naranja: #E07A3F;        /* Badges "OFERTA" */
  --pauze-naranja-dark: #B85C28;
  --pauze-naranja-bright: #FF8C3D;
  --pauze-rojo: #A03A2C;            /* Precio tachado, urgencia */
  --pauze-rojo-dark: #7A2A1F;
  --pauze-dorado: #C9954E;          /* Estrellas, premios */
  --pauze-dorado-dark: #A67B3F;

  /* === ESTADOS === */
  --pauze-success: #2A5C20;
  --pauze-warning: #E07A3F;
  --pauze-danger: #A03A2C;

  /* === SOMBRAS === */
  --pauze-shadow-sm: 0 2px 8px rgba(46, 31, 20, 0.08);
  --pauze-shadow-md: 0 6px 20px rgba(46, 31, 20, 0.12);
  --pauze-shadow-lg: 0 16px 40px rgba(46, 31, 20, 0.18);
  --pauze-shadow-cta: 0 8px 24px rgba(59, 122, 44, 0.4);
  --pauze-shadow-cta-orange: 0 8px 24px rgba(224, 122, 63, 0.4);

  /* === TYPOGRAPHY === */
  --pauze-font-display: 'Cormorant Garamond', Georgia, serif;
  --pauze-font-body: 'DM Sans', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;

  /* === SPACING === */
  --pauze-section-pad: clamp(3rem, 6.5vw, 5.5rem);
  --pauze-radius-pill: 999px;
  --pauze-radius-card: 16px;
  --pauze-radius-input: 8px;

  /* === LAYOUT === */
  --pauze-container-max: 1280px;
  --pauze-container-pad: clamp(1rem, 3vw, 2.5rem);
}

/* === RESET / NORMALIZE === */
.pauze-page * { box-sizing: border-box; }
.pauze-page { 
  font-family: var(--pauze-font-body); 
  color: var(--pauze-off-black);
  -webkit-font-smoothing: antialiased;
  line-height: 1.5;
}
.pauze-page img { max-width: 100%; display: block; }

/* === CONTAINER === */
.pauze-container {
  max-width: var(--pauze-container-max);
  margin: 0 auto;
  padding-left: var(--pauze-container-pad);
  padding-right: var(--pauze-container-pad);
}

/* === HEADINGS === */
.pauze-h1, .pauze-h2, .pauze-h3, .pauze-h4 {
  font-family: var(--pauze-font-display);
  color: var(--pauze-cacao);
  line-height: 1.1;
  letter-spacing: -0.02em;
  font-weight: 600;
}
.pauze-h1 {
  font-size: clamp(2.5rem, 6.5vw, 4.2rem);
  font-style: italic;
}
.pauze-h2 {
  font-size: clamp(2rem, 4.8vw, 3rem);
  font-style: italic;
  font-weight: 500;
}
.pauze-h3 {
  font-size: clamp(1.3rem, 2.5vw, 1.75rem);
  font-style: italic;
  font-weight: 600;
}
.pauze-h4 {
  font-size: clamp(1.05rem, 1.5vw, 1.25rem);
  font-weight: 700;
  font-style: normal;
  font-family: var(--pauze-font-body);
  letter-spacing: 0.02em;
}

/* === EYEBROW (etiqueta sobre H2) === */
.pauze-eyebrow {
  display: inline-block;
  font-size: 0.75rem;
  font-weight: 700;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--pauze-verde-dark);
  margin-bottom: 0.85rem;
}
.pauze-eyebrow--gold { color: var(--pauze-dorado-dark); }
.pauze-eyebrow--cream { color: var(--pauze-dorado); }
.pauze-eyebrow--orange { color: var(--pauze-naranja-dark); }

/* === BOTONES === */
.pauze-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 0.5rem;
  font-family: var(--pauze-font-body);
  font-weight: 700;
  padding: 1rem 2rem;
  border-radius: var(--pauze-radius-pill);
  border: 2px solid transparent;
  text-decoration: none;
  cursor: pointer;
  transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
  letter-spacing: 0.04em;
  font-size: 0.92rem;
  text-transform: uppercase;
  line-height: 1;
}
.pauze-btn--verde {
  background: var(--pauze-verde);
  color: white;
  box-shadow: var(--pauze-shadow-cta);
}
.pauze-btn--verde:hover {
  background: var(--pauze-verde-dark);
  transform: translateY(-2px);
  box-shadow: 0 12px 28px rgba(59, 122, 44, 0.55);
}
.pauze-btn--cacao {
  background: var(--pauze-cacao);
  color: var(--pauze-crema);
}
.pauze-btn--cacao:hover {
  background: var(--pauze-cacao-dark);
  transform: translateY(-2px);
  box-shadow: var(--pauze-shadow-md);
}
.pauze-btn--naranja {
  background: var(--pauze-naranja);
  color: white;
  box-shadow: var(--pauze-shadow-cta-orange);
}
.pauze-btn--naranja:hover {
  background: var(--pauze-naranja-dark);
  transform: translateY(-2px);
}
.pauze-btn--crema {
  background: var(--pauze-crema);
  color: var(--pauze-cacao);
}
.pauze-btn--crema:hover {
  background: white;
  transform: translateY(-2px);
}
.pauze-btn--outline-cacao {
  background: transparent;
  color: var(--pauze-cacao);
  border-color: var(--pauze-cacao);
}
.pauze-btn--outline-cacao:hover {
  background: var(--pauze-cacao);
  color: var(--pauze-crema);
}
.pauze-btn--outline-white {
  background: transparent;
  color: var(--pauze-crema);
  border-color: var(--pauze-crema);
}
.pauze-btn--outline-white:hover {
  background: var(--pauze-crema);
  color: var(--pauze-cacao);
}
.pauze-btn--lg { padding: 1.25rem 2.5rem; font-size: 1rem; }
.pauze-btn--sm { padding: 0.65rem 1.4rem; font-size: 0.8rem; }
.pauze-btn--block { width: 100%; }

/* === BADGES === */
.pauze-badge {
  display: inline-flex;
  align-items: center;
  gap: 0.4rem;
  padding: 0.4rem 0.85rem;
  border-radius: var(--pauze-radius-pill);
  font-size: 0.7rem;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  white-space: nowrap;
  line-height: 1;
}
.pauze-badge--verde { background: var(--pauze-verde); color: white; }
.pauze-badge--naranja { background: var(--pauze-naranja); color: white; }
.pauze-badge--rojo { background: var(--pauze-rojo); color: white; }
.pauze-badge--dorado { background: var(--pauze-dorado); color: white; }
.pauze-badge--cacao { background: var(--pauze-cacao); color: var(--pauze-crema); }
.pauze-badge--outline {
  background: transparent;
  border: 1.5px solid currentColor;
}

/* === CARDS === */
.pauze-card {
  background: white;
  border: 2px solid var(--pauze-arena);
  border-radius: var(--pauze-radius-card);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  overflow: hidden;
}
.pauze-card:hover {
  transform: translateY(-4px);
  box-shadow: var(--pauze-shadow-lg);
  border-color: var(--pauze-verde-bright);
}

/* === SECCIONES === */
.pauze-section { padding: var(--pauze-section-pad) 0; }
.pauze-section--cacao {
  background: var(--pauze-cacao);
  color: var(--pauze-crema);
}
.pauze-section--cacao-dark { background: var(--pauze-cacao-dark); color: var(--pauze-crema); }
.pauze-section--crema { background: var(--pauze-crema); }
.pauze-section--off-white { background: var(--pauze-off-white); }
.pauze-section--verde-pale { background: var(--pauze-verde-pale); }
.pauze-section--cacao .pauze-h1,
.pauze-section--cacao .pauze-h2,
.pauze-section--cacao .pauze-h3,
.pauze-section--cacao-dark .pauze-h1,
.pauze-section--cacao-dark .pauze-h2,
.pauze-section--cacao-dark .pauze-h3 { color: var(--pauze-crema); }

.pauze-section__header {
  text-align: center;
  max-width: 760px;
  margin: 0 auto 2.5rem;
}
.pauze-section__sub {
  font-size: 1.02rem;
  line-height: 1.6;
  color: var(--pauze-gris-dark);
  margin-top: 0.75rem;
}
.pauze-section--cacao .pauze-section__sub,
.pauze-section--cacao-dark .pauze-section__sub { color: var(--pauze-beige); }

/* === INPUT === */
.pauze-input {
  padding: 0.95rem 1.1rem;
  border: 1.5px solid var(--pauze-arena);
  background: white;
  border-radius: var(--pauze-radius-input);
  font-family: var(--pauze-font-body);
  font-size: 0.95rem;
  color: var(--pauze-off-black);
  transition: border-color 0.2s;
  width: 100%;
}
.pauze-input:focus {
  outline: none;
  border-color: var(--pauze-verde);
  box-shadow: 0 0 0 3px rgba(59, 122, 44, 0.1);
}

/* === ANIMACIONES === */
@keyframes pauze-marquee {
  from { transform: translateX(0); }
  to { transform: translateX(-50%); }
}
@keyframes pauze-fade-in-up {
  from { opacity: 0; transform: translateY(20px); }
  to { opacity: 1; transform: translateY(0); }
}
@keyframes pauze-pulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.05); }
}

/* === SCROLL ANIMATION === */
.pauze-reveal {
  opacity: 0;
  transform: translateY(20px);
  transition: opacity 0.6s ease, transform 0.6s ease;
}
.pauze-reveal.is-visible {
  opacity: 1;
  transform: translateY(0);
}

/* === UTILS === */
.pauze-text-center { text-align: center; }
.pauze-mt-1 { margin-top: 0.5rem; }
.pauze-mt-2 { margin-top: 1rem; }
.pauze-mt-3 { margin-top: 1.5rem; }
.pauze-mt-4 { margin-top: 2rem; }
.pauze-italic { font-style: italic; }
</style>

<script>
// Scroll reveal observer
document.addEventListener('DOMContentLoaded', function() {
  if ('IntersectionObserver' in window) {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.12 });
    document.querySelectorAll('.pauze-reveal').forEach(el => observer.observe(el));
  }
});
</script>
