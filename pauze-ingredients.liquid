    }
  ],
  "blocks": [
    {
      "type": "ingredient",
      "name": "Ingrediente",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Ilustración"
        },
        {
          "type": "text",
          "id": "icon",
          "label": "Emoji fallback",
          "default": "🌿"
        },
        {
          "type": "color",
