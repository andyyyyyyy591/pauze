    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subtítulo",
      "default": "Las cantidades de cada activo en el frente del pack. Sin blends ni números mágicos escondidos."
    },
    {
      "type": "textarea",
      "id": "disclaimer",
      "label": "Disclaimer ANMAT",
