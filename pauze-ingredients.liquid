  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "Pauze: Ingredientes",
      "blocks": [
        {
          "type": "ingredient",
          "settings": {
            "icon": "🍃",
            "dose": "200mg",
            "name": "L-teanina",
