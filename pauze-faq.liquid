{% comment %}
  ============================================
  PAUZE FAQ — Con tabs (Product/Shipping/Other)
  ============================================
  Replica el bloque FAQ de O Positiv PDP.
  3 tabs con acordeones en cada uno.
  
  USAR EN: home + PDP + página FAQ
{% endcomment %}

<section class="pauze-page pauze-section pauze-faq" 
         style="background: {{ section.settings.bg_color | default: '#F6F1E9' }};">
  <div class="pauze-container">
    <div class="pauze-faq__layout">
      <div class="pauze-faq__header pauze-reveal">
        <span class="pauze-eyebrow">{{ section.settings.eyebrow | default: 'Preguntas frecuentes' }}</span>
        <h2 class="pauze-h2">{{ section.settings.heading | default: 'Lo que más nos preguntan' }}</h2>
        {%- if section.settings.subheading != blank -%}
          <p class="pauze-section__sub">{{ section.settings.subheading }}</p>
        {%- endif -%}
        {%- if section.settings.contact_email != blank -%}
          <p class="pauze-faq__contact">
            ¿No encontrás tu duda? Escribinos a <a href="mailto:{{ section.settings.contact_email }}">{{ section.settings.contact_email }}</a>
          </p>
        {%- endif -%}
      </div>
      <div class="pauze-faq__content pauze-reveal">
        <div class="pauze-faq__tabs">
          <button class="pauze-faq__tab pauze-faq__tab--active" data-tab="producto" onclick="pauzeFaqTab(this, 'producto')">Producto</button>
          <button class="pauze-faq__tab" data-tab="envios" onclick="pauzeFaqTab(this, 'envios')">Envíos</button>
          <button class="pauze-faq__tab" data-tab="suscripcion" onclick="pauzeFaqTab(this, 'suscripcion')">Suscripción</button>
        </div>
        
        {%- assign tabs = 'producto,envios,suscripcion' | split: ',' -%}
        {%- for tab in tabs -%}
          <div class="pauze-faq__panel{% if forloop.first %} pauze-faq__panel--active{% endif %}" data-panel="{{ tab }}">
            {%- for block in section.blocks -%}
              {%- if block.settings.tab == tab -%}
                <details class="pauze-faq__item" {{ block.shopify_attributes }}>
                  <summary class="pauze-faq__q">
                    <span>{{ block.settings.question }}</span>
                    <span class="pauze-faq__icon">+</span>
                  </summary>
                  <div class="pauze-faq__a">
                    {{ block.settings.answer }}
                  </div>
                </details>
              {%- endif -%}
            {%- endfor -%}
          </div>
        {%- endfor -%}
      </div>
    </div>
  </div>
</section>

<style>
.pauze-faq__layout {
  display: grid;
  grid-template-columns: 1fr;
  gap: 2rem;
}
@media (min-width: 900px) {
  .pauze-faq__layout {
    grid-template-columns: 320px 1fr;
    gap: 4rem;
  }
}
.pauze-faq__contact {
  font-size: 0.92rem;
  color: var(--pauze-gris-dark);
  margin-top: 1rem;
}
.pauze-faq__contact a { color: var(--pauze-verde-dark); font-weight: 600; }

.pauze-faq__tabs {
  display: flex;
  gap: 0.5rem;
  border-bottom: 2px solid var(--pauze-arena);
  margin-bottom: 1.5rem;
  overflow-x: auto;
  padding-bottom: 0;
}
.pauze-faq__tab {
  background: transparent;
  border: none;
  cursor: pointer;
  padding: 0.85rem 1.4rem;
  font-family: var(--pauze-font-body);
  font-size: 0.92rem;
  font-weight: 600;
  color: var(--pauze-gris);
  border-bottom: 3px solid transparent;
  margin-bottom: -2px;
  transition: all 0.2s ease;
  white-space: nowrap;
}
.pauze-faq__tab:hover { color: var(--pauze-cacao); }
.pauze-faq__tab--active {
  color: var(--pauze-cacao);
  border-bottom-color: var(--pauze-verde);
  font-weight: 700;
}

.pauze-faq__panel { display: none; }
.pauze-faq__panel--active { display: block; }

.pauze-faq__item {
  border-bottom: 1px solid var(--pauze-arena);
}
.pauze-faq__q {
  list-style: none;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 1.3rem 0;
  font-size: 1rem;
  font-weight: 600;
  color: var(--pauze-cacao);
  cursor: pointer;
  gap: 1rem;
}
.pauze-faq__q::-webkit-details-marker { display: none; }
.pauze-faq__icon {
  width: 32px;
  height: 32px;
  border-radius: 50%;
  background: var(--pauze-verde-pale);
  color: var(--pauze-verde-dark);
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 1.2rem;
  font-weight: 700;
  transition: all 0.25s ease;
  flex-shrink: 0;
}
.pauze-faq__item[open] .pauze-faq__icon {
  background: var(--pauze-verde);
  color: white;
  transform: rotate(45deg);
}
.pauze-faq__a {
  padding: 0 0 1.3rem;
  font-size: 0.95rem;
  line-height: 1.65;
  color: var(--pauze-off-black);
}
.pauze-faq__a p { margin-bottom: 0.65rem; }
.pauze-faq__a p:last-child { margin-bottom: 0; }
</style>

<script>
function pauzeFaqTab(btn, tabName) {
  // Tab buttons
  const allTabs = btn.parentElement.querySelectorAll('.pauze-faq__tab');
  allTabs.forEach(t => t.classList.remove('pauze-faq__tab--active'));
  btn.classList.add('pauze-faq__tab--active');
  // Panels
  const container = btn.closest('.pauze-faq__content');
  const allPanels = container.querySelectorAll('.pauze-faq__panel');
  allPanels.forEach(p => p.classList.remove('pauze-faq__panel--active'));
  const panel = container.querySelector('[data-panel="' + tabName + '"]');
  if (panel) panel.classList.add('pauze-faq__panel--active');
}
</script>

{% schema %}
{
  "name": "Pauze: FAQ con tabs",
  "tag": "section",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Fondo",
      "default": "#F6F1E9"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Preguntas frecuentes"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Título",
      "default": "Lo que más nos preguntan"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subtítulo"
    },
    {
      "type": "text",
      "id": "contact_email",
      "label": "Email contacto",
      "default": "contacto@pauze.store"
    }
  ],
  "blocks": [
    {
      "type": "faq",
      "name": "Pregunta",
      "settings": [
        {
          "type": "select",
          "id": "tab",
          "label": "Tab",
          "options": [
            { "value": "producto", "label": "Producto" },
            { "value": "envios", "label": "Envíos" },
            { "value": "suscripcion", "label": "Suscripción" }
          ],
          "default": "producto"
        },
        { "type": "text", "id": "question", "label": "Pregunta", "default": "¿Tiene melatonina?" },
        { "type": "richtext", "id": "answer", "label": "Respuesta", "default": "<p>No. La melatonina en Argentina se considera medicamento. Pauze usa activos botánicos y aminoácidos que ayudan a tu cuerpo a producir su propia melatonina naturalmente.</p>" }
      ]
    }
  ],
  "max_blocks": 30,
  "presets": [
    {
      "name": "Pauze: FAQ con tabs",
      "blocks": [
        { "type": "faq", "settings": { "tab": "producto", "question": "¿Tiene melatonina?", "answer": "<p>No. La melatonina en Argentina se considera medicamento. Pauze usa activos botánicos y aminoácidos que ayudan a tu cuerpo a producir su propia melatonina naturalmente.</p>" } },
        { "type": "faq", "settings": { "tab": "producto", "question": "¿Cuándo lo tengo que tomar?", "answer": "<p>Entre 30 y 45 minutos antes de meterte en la cama. Lo ideal es que sea parte de un ritual repetido todas las noches para que tu cuerpo aprenda la asociación.</p>" } },
        { "type": "faq", "settings": { "tab": "producto", "question": "¿Tiene azúcar?", "answer": "<p>No. Pauze está endulzado con eritritol y stevia. Una taza tiene menos de 1g de carbohidratos digestibles. Apto para keto, ayuno intermitente y plan de descenso.</p>" } },
        { "type": "faq", "settings": { "tab": "producto", "question": "¿Es seguro tomarlo todas las noches?", "answer": "<p>Sí. Pauze está formulado para uso diario. Si tomás medicación, consultá con tu médico antes de incorporarlo.</p>" } },
        { "type": "faq", "settings": { "tab": "producto", "question": "¿En cuánto tiempo voy a notar la diferencia?", "answer": "<p>La mayoría nota mejoría en la primera semana — sobre todo en la rapidez con la que se duerme. Los efectos profundos se ven a las 3 semanas de uso consistente.</p>" } },
        { "type": "faq", "settings": { "tab": "producto", "question": "¿Cómo se prepara?", "answer": "<p>Calentá 200ml de la leche que prefieras (vaca, almendra, avena). Sumá un scoop (10g) directo a la taza. Batí 30 segundos con cuchara, frother o licuadora. Listo.</p>" } },
        { "type": "faq", "settings": { "tab": "envios", "question": "¿Cuánto tarda el envío?", "answer": "<p>Despachamos en 7 a 15 días hábiles después de tu compra. Enviamos a todo el país con Andreani y Correo Argentino.</p>" } },
        { "type": "faq", "settings": { "tab": "envios", "question": "¿Cuánto cuesta el envío?", "answer": "<p>Envío gratis a partir de $39.900 (todos los packs). Por debajo de ese monto, el envío es a cargo del comprador (suele estar entre $3.500 y $7.500 según zona).</p>" } },
        { "type": "faq", "settings": { "tab": "envios", "question": "¿Hacen envío prioritario?", "answer": "<p>Por ahora no. Estamos en proceso de optimizar la logística para sumar envío prioritario en 24-48hs. Esperamos tenerlo disponible en los próximos meses.</p>" } },
        { "type": "faq", "settings": { "tab": "envios", "question": "¿Puedo rastrear mi pedido?", "answer": "<p>Sí. Cuando despachamos tu pedido, te llega un email con el código de seguimiento de Andreani/Correo Argentino.</p>" } },
        { "type": "faq", "settings": { "tab": "suscripcion", "question": "¿Cómo funciona la suscripción?", "answer": "<p>Te llega un pack todos los meses, con 20% de descuento vs compra única, envío gratis siempre y la guía PDF gratis. Cancelás cuando quieras desde tu cuenta o por email.</p>" } },
        { "type": "faq", "settings": { "tab": "suscripcion", "question": "¿Puedo cancelar cuando quiera?", "answer": "<p>Sí. Sin permanencia, sin letra chica. Lo cancelás desde tu cuenta en un click o nos escribís a contacto@pauze.store y lo hacemos nosotros.</p>" } },
        { "type": "faq", "settings": { "tab": "suscripcion", "question": "¿Puedo pausar un mes si me sobra producto?", "answer": "<p>Sí. Podés pausar tu suscripción por uno o dos meses cuando quieras desde tu cuenta. Cuando reanudás, vuelve a llegar automáticamente.</p>" } },
        { "type": "faq", "settings": { "tab": "suscripcion", "question": "¿Y si no me funciona?", "answer": "<p>Tenés 14 noches de garantía. Si no notás la diferencia, te devolvemos el dinero como crédito en la tienda. Sin necesidad de devolver el pack.</p>" } }
      ]
    }
  ]
}
{% endschema %}
