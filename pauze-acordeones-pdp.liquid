{% comment %}
  PAUZE ACORDEONES PDP — Réplica de los 4 acordeones de O Positiv URO PDP:
  Is This For You? / Benefits / Recommended Usage / Ingredient Facts
{% endcomment %}

<section class="pauze-section pauze-section--crema pauze-acordeones-pdp" data-section-id="{{ section.id }}">
  <div class="pauze-container">
    <div class="pauze-acordeones-pdp__list">
      {% for block in section.blocks %}
        <details class="pauze-acord" {% if block.settings.open_by_default %}open{% endif %}>
          <summary class="pauze-acord__summary">
            <span class="pauze-acord__title">{{ block.settings.title }}</span>
            <span class="pauze-acord__icon">+</span>
          </summary>
          <div class="pauze-acord__body">
            {{ block.settings.content }}
          </div>
        </details>
      {% endfor %}
    </div>
  </div>
</section>

<style>
.pauze-acordeones-pdp__list {
  max-width: 880px;
  margin: 0 auto;
  display: flex;
  flex-direction: column;
  gap: 0.85rem;
}
.pauze-acord {
  background: white;
  border-radius: 14px;
  border: 1px solid var(--pauze-arena);
  overflow: hidden;
  transition: all 0.3s ease;
}
.pauze-acord[open] {
  border-color: var(--pauze-verde);
  box-shadow: var(--pauze-shadow-md);
}
.pauze-acord__summary {
  list-style: none;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 1.35rem 1.5rem;
  cursor: pointer;
  gap: 1rem;
}
.pauze-acord__summary::-webkit-details-marker { display: none; }
.pauze-acord__title {
  font-family: var(--pauze-font-display);
  font-style: italic;
  font-weight: 600;
  font-size: 1.35rem;
  color: var(--pauze-cacao);
}
.pauze-acord__icon {
  width: 34px;
  height: 34px;
  border-radius: 50%;
  background: var(--pauze-verde-pale);
  color: var(--pauze-verde-dark);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1.4rem;
  font-weight: 700;
  flex-shrink: 0;
  transition: all 0.25s ease;
}
.pauze-acord[open] .pauze-acord__icon {
  background: var(--pauze-verde);
  color: white;
  transform: rotate(45deg);
}
.pauze-acord__body {
  padding: 0 1.5rem 1.75rem;
  font-size: 0.95rem;
  line-height: 1.7;
  color: var(--pauze-off-black);
}
.pauze-acord__body ul {
  padding-left: 0;
  list-style: none;
  margin: 0.5rem 0;
}
.pauze-acord__body li {
  padding-left: 1.85rem;
  position: relative;
  margin-bottom: 0.6rem;
}
.pauze-acord__body li::before {
  content: '✓';
  position: absolute;
  left: 0;
  width: 22px;
  height: 22px;
  background: var(--pauze-verde-pale);
  color: var(--pauze-verde-dark);
  border-radius: 50%;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 0.7rem;
  font-weight: 700;
  top: 1px;
}
</style>

