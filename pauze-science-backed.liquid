{% comment %}
  ============================================
  PAUZE SCIENCE-BACKED — Avalado por la ciencia
  ============================================
  Reemplazo de "Medical Team" de O Positiv.
  Muestra papers reales que respaldan los activos.
  Más fuerte y honesto que endorsements falsos.
  
  USAR EN: home (después de testimonios) o PDP
{% endcomment %}

<section class="pauze-page pauze-section pauze-science-backed" 
         style="background: {{ section.settings.bg_color | default: '#FAFAF8' }};">
  <div class="pauze-container">
    <div class="pauze-section__header pauze-reveal">
      <span class="pauze-eyebrow">{{ section.settings.eyebrow | default: 'Avalado por la ciencia' }}</span>
      <h2 class="pauze-h2">{{ section.settings.heading | default: 'Cada activo, respaldado por papers reales' }}</h2>
      {%- if section.settings.subheading != blank -%}
        <p class="pauze-section__sub">{{ section.settings.subheading }}</p>
      {%- endif -%}
    </div>

    <div class="pauze-science-backed__grid">
      {%- for block in section.blocks -%}
        <article class="pauze-science-backed__card pauze-reveal" {{ block.shopify_attributes }}>
          <div class="pauze-science-backed__icon">📄</div>
          <div class="pauze-science-backed__journal">{{ block.settings.journal }}</div>
          <div class="pauze-science-backed__year">{{ block.settings.year }}</div>
          <h3 class="pauze-science-backed__title">{{ block.settings.title }}</h3>
          <p class="pauze-science-backed__finding">{{ block.settings.finding }}</p>
          {%- if block.settings.link != blank -%}
            <a href="{{ block.settings.link }}" class="pauze-science-backed__link" target="_blank" rel="noopener">
              Leer el estudio →
            </a>
          {%- endif -%}
        </article>
      {%- endfor -%}
    </div>

    <p class="pauze-science-backed__note">
      {{ section.settings.legal_note | default: 'Estos estudios respaldan la eficacia de los activos individualmente. Pauze no es un medicamento ni reemplaza el consejo médico. Los resultados pueden variar.' }}
    </p>
  </div>
</section>

<style>
.pauze-science-backed__grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 1.25rem;
  max-width: 1100px;
  margin: 0 auto;
}
@media (min-width: 768px) {
  .pauze-science-backed__grid { grid-template-columns: repeat(3, 1fr); gap: 1.5rem; }
}
.pauze-science-backed__card {
  background: white;
  border: 2px solid var(--pauze-arena);
  border-radius: 16px;
  padding: 1.75rem;
  display: flex;
  flex-direction: column;
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
}
.pauze-science-backed__card:hover {
  border-color: var(--pauze-verde-bright);
  transform: translateY(-4px);
  box-shadow: var(--pauze-shadow-md);
}
.pauze-science-backed__card::after {
  content: '';
  position: absolute;
  top: 0; right: 0;
  width: 80px;
  height: 80px;
  background: radial-gradient(circle at top right, rgba(93, 170, 63, 0.08), transparent 70%);
}
.pauze-science-backed__icon {
  font-size: 2rem;
  margin-bottom: 0.85rem;
  opacity: 0.85;
}
.pauze-science-backed__journal {
  font-size: 0.72rem;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--pauze-verde-dark);
  margin-bottom: 0.2rem;
}
.pauze-science-backed__year {
  font-family: var(--pauze-font-display);
  font-style: italic;
  font-weight: 600;
  color: var(--pauze-dorado-dark);
  font-size: 1.05rem;
  margin-bottom: 0.65rem;
}
.pauze-science-backed__title {
  font-family: var(--pauze-font-display);
  font-style: italic;
  font-weight: 600;
  font-size: 1.2rem;
  color: var(--pauze-cacao);
  line-height: 1.25;
  margin: 0 0 0.85rem;
}
.pauze-science-backed__finding {
  font-size: 0.9rem;
  line-height: 1.6;
  color: var(--pauze-off-black);
  margin: 0 0 1rem;
  flex-grow: 1;
}
.pauze-science-backed__link {
  font-size: 0.85rem;
  font-weight: 700;
  color: var(--pauze-verde-dark);
  text-decoration: none;
  letter-spacing: 0.02em;
  border-bottom: 1.5px solid var(--pauze-verde);
  padding-bottom: 2px;
  align-self: flex-start;
}
.pauze-science-backed__link:hover { color: var(--pauze-verde); }
.pauze-science-backed__note {
  text-align: center;
  margin-top: 2.5rem;
  font-size: 0.78rem;
  color: var(--pauze-gris-dark);
  font-style: italic;
  max-width: 680px;
  margin-left: auto;
  margin-right: auto;
  line-height: 1.55;
}
</style>

{% schema %}
{
  "name": "Pauze: Avalado por la ciencia",
  "tag": "section",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Fondo",
      "default": "#FAFAF8"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Avalado por la ciencia"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Título",
      "default": "Cada activo, respaldado por papers reales"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subtítulo",
      "default": "No te pedimos que confíes en nosotros — confiá en la evidencia. Estos son los papers que avalan los activos que usamos."
    },
    {
      "type": "textarea",
      "id": "legal_note",
      "label": "Nota legal",
      "default": "Estos estudios respaldan la eficacia de los activos individualmente. Pauze no es un medicamento ni reemplaza el consejo médico. Los resultados pueden variar."
    }
  ],
  "blocks": [
    {
      "type": "paper",
      "name": "Paper",
      "settings": [
        { "type": "text", "id": "journal", "label": "Journal", "default": "Asia Pacific J Clin Nutr" },
        { "type": "text", "id": "year", "label": "Año", "default": "2008" },
        { "type": "text", "id": "title", "label": "Título estudio", "default": "L-teanina y estado mental" },
        { "type": "textarea", "id": "finding", "label": "Hallazgo principal", "default": "La L-teanina (200mg) aumenta significativamente la actividad de ondas alpha cerebrales — el patrón asociado a la relajación atenta." },
        { "type": "url", "id": "link", "label": "Link al paper (PubMed/journal)" }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "Pauze: Avalado por la ciencia",
      "blocks": [
        { "type": "paper", "settings": { "journal": "Asia Pacific J Clin Nutr", "year": "2008", "title": "L-teanina y ondas alpha cerebrales", "finding": "La L-teanina (200mg) aumenta significativamente la actividad de ondas alpha — el patrón asociado a la relajación atenta sin sedación.", "link": "https://pubmed.ncbi.nlm.nih.gov/18296328/" } },
        { "type": "paper", "settings": { "journal": "Phytomedicine", "year": "2019", "title": "Apigenina y receptores GABA", "finding": "La apigenina se une a receptores GABA-A en el cerebro, produciendo efectos ansiolíticos suaves similares a la manzanilla concentrada.", "link": "https://pubmed.ncbi.nlm.nih.gov/30668053/" } },
        { "type": "paper", "settings": { "journal": "J Res Med Sci", "year": "2012", "title": "Magnesio y sueño en adultos", "finding": "La suplementación con magnesio mejora significativamente la calidad del sueño, reduce el tiempo de latencia y aumenta el sueño profundo.", "link": "https://pubmed.ncbi.nlm.nih.gov/23853635/" } }
      ]
    }
  ]
}
{% endschema %}
