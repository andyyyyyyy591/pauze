{% comment %}
  PAUZE RELATED CAROUSEL — Réplica del carrusel dinámico de productos de O Positiv
  Como solo tenemos 1 producto: "Próximamente" con sabores futuros + accesorios
  Genera deseo y comunica roadmap
{% endcomment %}

<section class="pauze-section pauze-related-carousel" 
         style="background: {{ section.settings.bg_color | default: '#F6F1E9' }};"
         data-section-id="{{ section.id }}">
  <div class="pauze-container">
    <div class="pauze-section__header pauze-reveal">
      <span class="pauze-eyebrow pauze-eyebrow--orange">{{ section.settings.eyebrow | default: 'PRÓXIMAMENTE EN PAUZE' }}</span>
      <h2 class="pauze-h2">{{ section.settings.heading | default: 'Lo que viene en la familia' }}</h2>
      {% if section.settings.sub != blank %}
        <p class="pauze-section__sub">{{ section.settings.sub }}</p>
      {% endif %}
    </div>

    <div class="pauze-related-carousel__scroll">
      {% for block in section.blocks %}
        <article class="pauze-related-carousel__card pauze-reveal" 
                 style="background: {{ block.settings.bg_color | default: '#5A3E2B' }};"
                 {{ block.shopify_attributes }}>
          <div class="pauze-related-carousel__top">
            {% if block.settings.tag != blank %}
              <span class="pauze-related-carousel__tag">{{ block.settings.tag }}</span>
            {% endif %}
            <span class="pauze-related-carousel__category">PAUZE · {{ block.settings.category | upcase }}</span>
          </div>
          <div class="pauze-related-carousel__visual">
            {% if block.settings.image != blank %}
              <img src="{{ block.settings.image | image_url: width: 600 }}" alt="{{ block.settings.name }}" loading="lazy">
            {% else %}
              <div class="pauze-related-carousel__emoji">{{ block.settings.emoji | default: '☕' }}</div>
            {% endif %}
          </div>
          <div class="pauze-related-carousel__bottom">
            <h3 class="pauze-related-carousel__name">{{ block.settings.name }}</h3>
            <p class="pauze-related-carousel__desc">{{ block.settings.desc }}</p>
            <a href="{{ block.settings.url | default: '#' }}" class="pauze-related-carousel__cta">
              {{ block.settings.cta | default: 'Sumate a la lista' }} →
            </a>
          </div>
        </article>
      {% endfor %}
    </div>
  </div>
</section>

<style>
.pauze-related-carousel__scroll {
  display: flex;
  gap: 1rem;
  overflow-x: auto;
  padding-bottom: 1rem;
  scroll-snap-type: x mandatory;
  -webkit-overflow-scrolling: touch;
}
.pauze-related-carousel__scroll::-webkit-scrollbar { height: 8px; }
.pauze-related-carousel__scroll::-webkit-scrollbar-track { background: var(--pauze-arena); border-radius: 4px; }
.pauze-related-carousel__scroll::-webkit-scrollbar-thumb { background: var(--pauze-cacao); border-radius: 4px; }

.pauze-related-carousel__card {
  flex: 0 0 280px;
  border-radius: 20px;
  padding: 1.5rem;
  color: var(--pauze-crema);
  display: flex;
  flex-direction: column;
  scroll-snap-align: start;
  min-height: 380px;
  position: relative;
  overflow: hidden;
}
@media (min-width: 768px) {
  .pauze-related-carousel__card { flex: 0 0 320px; min-height: 420px; }
}

.pauze-related-carousel__top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 1rem;
  gap: 0.5rem;
  z-index: 1;
}
.pauze-related-carousel__tag {
  background: var(--pauze-naranja);
  color: white;
  padding: 0.3rem 0.65rem;
  border-radius: var(--pauze-radius-pill);
  font-size: 0.62rem;
  font-weight: 700;
  letter-spacing: 0.08em;
}
.pauze-related-carousel__category {
  font-size: 0.65rem;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  opacity: 0.7;
}

.pauze-related-carousel__visual {
  flex-grow: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 1rem 0;
}
.pauze-related-carousel__visual img { max-width: 100%; max-height: 200px; }
.pauze-related-carousel__emoji {
  font-size: 6rem;
  opacity: 0.85;
  text-align: center;
}

.pauze-related-carousel__bottom { z-index: 1; }
.pauze-related-carousel__name {
  font-family: var(--pauze-font-display);
  font-style: italic;
  font-weight: 600;
  font-size: 1.55rem;
  color: var(--pauze-crema);
  margin: 0 0 0.4rem;
  line-height: 1.15;
}
.pauze-related-carousel__desc {
  font-size: 0.85rem;
  opacity: 0.82;
  margin: 0 0 1rem;
  line-height: 1.45;
}
.pauze-related-carousel__cta {
  font-size: 0.82rem;
  font-weight: 700;
  letter-spacing: 0.04em;
  color: var(--pauze-crema);
  text-decoration: none;
  border-bottom: 1.5px solid currentColor;
  padding-bottom: 2px;
  display: inline-block;
}
</style>

{% schema %}
{
  "name": "Pauze: Carrusel próximamente",
  "tag": "section",
  "settings": [
    { "type": "color", "id": "bg_color", "label": "Fondo", "default": "#F6F1E9" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "PRÓXIMAMENTE EN PAUZE" },
    { "type": "text", "id": "heading", "label": "Título", "default": "Lo que viene en la familia" },
    { "type": "textarea", "id": "sub", "label": "Sub", "default": "Estamos trabajando en sabores nuevos y accesorios para tu ritual. Sumate a la lista de espera." }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Producto",
      "settings": [
        { "type": "color", "id": "bg_color", "label": "Fondo card", "default": "#5A3E2B" },
        { "type": "text", "id": "tag", "label": "Tag (NUEVO/PRÓXIMO/...)", "default": "PRÓXIMAMENTE" },
        { "type": "text", "id": "category", "label": "Categoría", "default": "PM BLEND" },
        { "type": "text", "id": "name", "label": "Nombre", "default": "Pauze Cocoa" },
        { "type": "textarea", "id": "desc", "label": "Descripción" },
        { "type": "text", "id": "emoji", "label": "Emoji fallback", "default": "☕" },
        { "type": "image_picker", "id": "image", "label": "Imagen" },
        { "type": "text", "id": "cta", "label": "CTA", "default": "Sumate a la lista" },
        { "type": "url", "id": "url", "label": "URL" }
      ]
    }
  ],
  "max_blocks": 8,
  "presets": [
    {
      "name": "Pauze: Carrusel próximamente",
      "blocks": [
        { "type": "product", "settings": { "bg_color": "#5A3E2B", "tag": "DISPONIBLE", "category": "PM BLEND", "name": "Pauze Cocoa", "desc": "Chocolatada nocturna con L-teanina, apigenina y magnesio.", "emoji": "🍫" } },
        { "type": "product", "settings": { "bg_color": "#2A5C20", "tag": "PRÓXIMAMENTE", "category": "PM BLEND", "name": "Pauze Matcha", "desc": "Versión matcha PM para quien prefiere otro sabor nocturno.", "emoji": "🍵" } },
        { "type": "product", "settings": { "bg_color": "#B85C28", "tag": "PRÓXIMAMENTE", "category": "PM BLEND", "name": "Pauze Vainilla", "desc": "Vainilla con activos PM. Para los que no comen chocolate.", "emoji": "🥛" } },
        { "type": "product", "settings": { "bg_color": "#3D2C1F", "tag": "PRÓXIMAMENTE", "category": "PM BLEND", "name": "Pauze Cocoa Especiado", "desc": "Cocoa con cardamomo, jengibre y un toque de canela.", "emoji": "🌶️" } },
        { "type": "product", "settings": { "bg_color": "#A03A2C", "tag": "ACCESORIO", "category": "RITUAL", "name": "Frother eléctrico", "desc": "Para que tu chocolatada haga la espuma perfecta.", "emoji": "🥄" } }
      ]
    }
  ]
}
{% endschema %}
