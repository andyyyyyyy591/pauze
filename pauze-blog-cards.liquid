          }
        },
        {
          "type": "post",
          "settings": {
            "placeholder_color": "#A03A2C",
            "emoji": "💊",
            "category": "Mito vs Ciencia",
            "title": "El mito de la melatonina",
            "excerpt": "Por qué la melatonina no es una pastilla mágica para dormir, y qué dice la evidencia sobre su uso real.",
            "url": "/blogs/ritual/el-mito-de-la-melatonina"
          }
        },
        {
          "type": "post",
          "settings": {
            "placeholder_color": "#B85C28",
            "emoji": "🍫",
            "category": "Comportamiento",
            "title": "Antojo dulce nocturno: qué es y cómo se calma",
            "excerpt": "El alfajor de las 11 no es debilidad. Es biología. Te contamos qué está pasando y qué podés hacer.",
            "url": "/blogs/ritual/antojo-dulce-nocturno"
          }
        }
      ]
    }
  ]
}
{% endschema %}
