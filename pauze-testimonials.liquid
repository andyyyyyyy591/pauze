        { "type": "testimonial", "settings": { "title": "Estaba escéptico", "body": "Compré por la garantía de 14 noches. Si no me funcionaba, devolvía. No tuve que devolver nada. Voy por mi tercer pack.", "name": "Bruno T.", "initial": "B" } }
