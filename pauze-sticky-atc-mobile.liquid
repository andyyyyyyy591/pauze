{% comment %}
  PAUZE STICKY ATC MOBILE — Barra fija abajo en mobile
  Aparece después de scrollear 600px y muestra precio + botón ATC
  Solo se ve en mobile (max-width 900px)
{% endcomment %}

<div class="pauze-sticky-atc" id="pauzeStickyAtc" data-section-id="{{ section.id }}">
  <div class="pauze-sticky-atc__inner">
    <div class="pauze-sticky-atc__info">
      <span class="pauze-sticky-atc__title">{{ section.settings.product_name | default: 'Pauze Cocoa' }}</span>
      <span class="pauze-sticky-atc__price" id="pauzeStickyPrice">$55.920</span>
    </div>
    <button class="pauze-sticky-atc__btn" onclick="pauzeStickyAtcClick()">
      AGREGAR →
    </button>
  </div>
</div>

<style>
.pauze-sticky-atc {
  position: fixed;
  bottom: -100px;
  left: 0; right: 0;
  background: white;
  border-top: 1px solid var(--pauze-arena);
  box-shadow: 0 -10px 30px rgba(0,0,0,0.15);
  z-index: 90;
  transition: bottom 0.35s cubic-bezier(0.16, 1, 0.3, 1);
  padding-bottom: env(safe-area-inset-bottom);
}
.pauze-sticky-atc.is-visible { bottom: 0; }
@media (min-width: 900px) {
  .pauze-sticky-atc { display: none; }
}
.pauze-sticky-atc__inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0.75rem 1rem;
  gap: 0.85rem;
}
.pauze-sticky-atc__info {
  display: flex;
  flex-direction: column;
  flex-grow: 1;
}
.pauze-sticky-atc__title {
  font-family: var(--pauze-font-display);
  font-style: italic;
  font-weight: 600;
  font-size: 1.05rem;
  color: var(--pauze-cacao);
  line-height: 1.1;
}
.pauze-sticky-atc__price {
  font-family: var(--pauze-font-body);
  font-weight: 700;
  font-size: 0.92rem;
  color: var(--pauze-verde-dark);
}
.pauze-sticky-atc__btn {
  background: var(--pauze-verde);
  color: white;
  border: none;
  padding: 0.95rem 1.5rem;
  font-family: var(--pauze-font-body);
  font-size: 0.9rem;
  font-weight: 700;
  border-radius: var(--pauze-radius-pill);
  letter-spacing: 0.05em;
  cursor: pointer;
  box-shadow: var(--pauze-shadow-cta);
  white-space: nowrap;
}
.pauze-sticky-atc__btn:active { transform: scale(0.98); }
</style>

<script>
(function() {
  const SCROLL_TRIGGER = {{ section.settings.scroll_trigger | default: 600 }};
  const sticky = document.getElementById('pauzeStickyAtc');
  if (!sticky) return;

  let isVisible = false;
  function checkScroll() {
    const shouldShow = window.scrollY > SCROLL_TRIGGER;
    if (shouldShow !== isVisible) {
      sticky.classList.toggle('is-visible', shouldShow);
      isVisible = shouldShow;
    }
  }

  window.addEventListener('scroll', checkScroll, { passive: true });

  window.pauzeStickyAtcClick = function() {
    // Trigger del ATC del bloque principal
    const mainAtc = document.getElementById('pauzeAtcBtn');
    if (mainAtc) {
      mainAtc.click();
      mainAtc.scrollIntoView({ behavior: 'smooth', block: 'center' });
    } else {
      window.location.href = '/products/pauze-cocoa';
    }
  };

  // Sync precio con el ATC principal (escucha el evento custom)
  window.pauzeStickyATCUpdate = function(price) {
    const el = document.getElementById('pauzeStickyPrice');
    if (el) el.textContent = '$' + Math.round(price).toLocaleString('es-AR');
  };
})();
</script>

{% schema %}
{
  "name": "Pauze: Sticky ATC mobile",
  "tag": "div",
  "settings": [
    { "type": "text", "id": "product_name", "label": "Nombre producto", "default": "Pauze Cocoa" },
    { "type": "range", "id": "scroll_trigger", "label": "Aparece después de (px)", "min": 200, "max": 1500, "step": 100, "default": 600, "unit": "px" }
  ],
  "presets": [{ "name": "Pauze: Sticky ATC mobile" }]
}
{% endschema %}
